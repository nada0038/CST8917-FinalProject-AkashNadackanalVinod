### LOCAL TESTING: Test the validation function locally
@validatorBaseUrl = http://localhost:7071/api

### 1) Valid expense under $100
POST {{validatorBaseUrl}}/validate_expense
Content-Type: application/json

{
  "employeeName": "Alice Smith",
  "employeeEmail": "alice@company.com",
  "amount": 45.50,
  "category": "meals",
  "description": "Client lunch",
  "managerEmail": "manager@company.com"
}

### 5) Missing required fields -> Validation Error
POST {{validatorBaseUrl}}/validate_expense
Content-Type: application/json

{
  "employeeName": "Eve Fox",
  "amount": 50.00,
  "category": "meals"
}

### 6) Invalid category -> Validation Error
POST {{validatorBaseUrl}}/validate_expense
Content-Type: application/json

{
  "employeeName": "Frank Castle",
  "employeeEmail": "frank@company.com",
  "amount": 10.00,
  "category": "weapons",
  "description": "Supplies",
  "managerEmail": "manager@company.com"
}


